generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  themeIndex    Int       @default(0)
  isAdmin       Boolean   @default(false)
  isRoyal       Boolean   @default(false)
  battlesWon    Int       @default(0)
  battlesTotal  Int       @default(0)
  rating        Int       @default(1000)
  rank          String    @default("Novice")
  dailyWins     Json      @default("{}") // Stores {"YYYY-MM-DD": count}
  notesData     Json      @default("{\"nodes\":[],\"edges\":[]}")
  createdAt     DateTime  @default(now())
  
  // Friend Request relations
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  
  accounts      Account[]
  sessions      Session[]
  submissions   Submission[]
  hostDuels     Duel[]    @relation("HostDuels")
  guestDuels    Duel[]    @relation("GuestDuels")
  aiPrompts     AiPrompt[]
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   // "PENDING", "ACCEPTED", "REJECTED"
  createdAt  DateTime @default(now())

  sender   User @relation("SentRequests", fields: [senderId], references: [id])
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Question {
  problemId   Int?     @unique
  id          String   @id @default(cuid())
  title       String   @unique
  description String
  restrictions String? // New field for problem constraints
  difficulty  String
  testCases   String   // JSON string of visible input/output pairs
  hiddenTestCases String? // JSON string of hidden input/output pairs
  idealComplexity String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submissions Submission[]
  duels       Duel[]
}

model Duel {
  id          String   @id @default(cuid())
  pin         String   @unique
  questionId  String
  status      String   // "WAITING", "ACTIVE", "FINISHED"
  
  hostId      String
  guestId     String?
  
  hostReady   Boolean  @default(false)
  guestReady  Boolean  @default(false)
  
  hostFinalized Boolean @default(false)
  guestFinalized Boolean @default(false)
  
  hostSolveTime  Int?    // time in milliseconds
  guestSolveTime Int?    // time in milliseconds
  hostComplexity Float?
  guestComplexity Float?
  hostPenalty    Float?
  guestPenalty   Float?
  
  hostRatingChange Int?
  guestRatingChange Int?
  
  hostCode      String?
  guestCode     String?
  finishReason  String?  // e.g., "SOLVED", "SURRENDERED", "TIMEOUT"
  
  // Real-time progress stats
  hostCodeLength  Int       @default(0)
  guestCodeLength Int       @default(0)
  hostLineCount   Int       @default(0)
  guestLineCount  Int       @default(0)
  hostTestsPassed Int       @default(0)
  guestTestsPassed Int      @default(0)
  hostTestsTotal  Int       @default(0)
  guestTestsTotal Int       @default(0)
  hostLastActive  DateTime?
  guestLastActive DateTime?

  createdAt   DateTime @default(now())
  startedAt   DateTime?
  unrated     Boolean  @default(false)
  gameMode    String   @default("CODEKNIGHTS")
  expiresAt   DateTime
  numProblems Int      @default(1)
  totalTime   Int      @default(30)
  difficulty  String   @default("ANY")
  questionIds String[] @default([])

  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  host        User     @relation("HostDuels", fields: [hostId], references: [id], onDelete: Cascade)
  guest       User?    @relation("GuestDuels", fields: [guestId], references: [id], onDelete: SetNull)
}

model Submission {
  id         String   @id @default(cuid())
  userId     String
  questionId String?
  code       String
  language   String
  status     String   // "PASSED" or "FAILED"
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AiPrompt {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
